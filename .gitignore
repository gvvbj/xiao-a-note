# ========================
# 1. 日志和本地系统缓存
# ========================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.local
.DS_Store

# ========================
# 2. 依赖包与编译/打包产物 (核心不提交部分)
# ========================
node_modules/
dist/
dist-ssr/
dist_electron/
plugins/             # 编译后的插件产物目录 (源码在 src 中)
*.tsbuildinfo

# ========================
# 3. 临时资产与无需共享的文档
# ========================
Fonts/               # 临时存放字体的目录
img/                 # 临时存放图片的目录
docs/                # 本地临时文档
temp_images/         # 运行时临时图片目录

# ========================
# 4. 测试报告与手动测试目录
# ========================
playwright-report/
test-results/
reports/
test/                # 个人手动测试产生的临时目录 (保留正式的 tests/ 目录)
test_file_*.md       # 测试生成的假文件

# ========================
# 5. AI 与智能体相关临时文件
# ========================
.claude/
ai-doc/
!.agent/mcp-servers

# ========================
# 6. 编辑器和 IDE 配置
# ========================
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
