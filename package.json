{
  "name": "frontend-notes",
  "private": true,
  "version": "4.11.0",
  "description": "A Markdown Note Taking Application",
  "author": "Xiao A Note Team",
  "type": "module",
  "scripts": {
    "dev": "npm run build:extensions && concurrently \"npm run dev:vite\" \"npm run electron:build && npm run dev:electron\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:extensions": "node scripts/build-extensions.cjs",
    "electron:build": "python scripts/build_electron.py",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev:vite": "vite",
    "build:electron": "npm run build:extensions && npm run electron:build && vite build && electron-builder",
    "build:complete": "node scripts/build-complete.cjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npx playwright test"
  },
  "build": {
    "appId": "com.xiaoanote.app",
    "productName": "小A笔记",
    "afterPack": "./scripts/afterPack.cjs",
    "copyright": "Copyright © 2024 Xiao A Note",
    "win": {
      "icon": "resources/icons/app图标.ico",
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icons/app图标.ico",
      "uninstallerIcon": "resources/icons/app图标.ico",
      "installerHeaderIcon": "resources/icons/app图标.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "小A笔记",
      "include": "resources/installer.nsh",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markdown 文档",
        "role": "Editor",
        "icon": "resources/icons/app图标.ico"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markdown 文档",
        "role": "Editor",
        "icon": "resources/icons/app图标.ico"
      }
    ],
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "package.json",
      "resources/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,LICENSE,license,readme}",
      "!**/node_modules/*/{test,tests,__tests__,spec,specs}/**",
      "!**/node_modules/**/*.map",
      "!**/{test,tests,__tests__,spec,specs}/**",
      "!**/*.test.{js,ts,tsx}",
      "!**/*.spec.{js,ts,tsx}",
      "!**/src/**",
      "!**/scripts/**",
      "!**/.git/**",
      "!**/temp_images/**",
      "!**/playwright-report/**",
      "!**/test-results/**",
      "!**/.gemini/**",
      "!**/*.md",
      "resources/**/*.md"
    ],
    "extraResources": [
      {
        "from": "resources/icons/",
        "to": "icons/",
        "filter": [
          "**/*"
        ]
      },
      "resources/bin"
    ],
    "extraFiles": [
      "plugins",
      "themes"
    ],
    "asar": true,
    "compression": "maximum"
  },
  "dependencies": {
    "@aarkue/tiptap-math-extension": "^1.4.0",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.9",
    "@lezer/common": "^1.5.0",
    "@tiptap/extension-emoji": "^3.14.0",
    "@tiptap/pm": "^3.14.0",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/marked": "^5.0.2",
    "@types/turndown": "^5.0.6",
    "@uiw/codemirror-theme-github": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "emoji-picker-react": "^4.16.1",
    "esbuild-wasm": "^0.27.3",
    "eventemitter3": "^5.0.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.11.0",
    "tailwind-merge": "^3.4.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.35",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  },
  "main": "electron/dist/main.cjs"
}